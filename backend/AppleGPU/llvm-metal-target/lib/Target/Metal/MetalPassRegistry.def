//===----------------------------------------------------------------------===//
//
// Registry of New-PM passes that are part of the Metal backend.
//
//===----------------------------------------------------------------------===//

// NOTE: NO INCLUDE GUARD DESIRED!

#ifndef MODULE_PASS
#define MODULE_PASS(NAME, CREATE_PASS)
#endif
MODULE_PASS("metal-inline-non-kernel", MetalInlineNonKernelPass())
MODULE_PASS("metal-lower-fneg", MetalLowerFNegPass())
MODULE_PASS("metal-nan-min-max", MetalNaNMinMaxPass())
MODULE_PASS("metal-llvm-to-air-intrinsics", MetalLLVMToAIRIntrinsicsPass())
MODULE_PASS("metal-barrier-rename", MetalBarrierRenamePass())
MODULE_PASS("metal-lower-atomic-rmw", MetalLowerAtomicRMWPass())
MODULE_PASS("metal-split-i64-shuffle", MetalSplitI64ShufflePass())
MODULE_PASS("metal-scalar-store-guard", MetalScalarStoreGuardPass())
MODULE_PASS("metal-tg-global-coalesce", MetalTGGlobalCoalescePass())
MODULE_PASS("metal-tg-barrier-insert", MetalTGBarrierInsertPass())
MODULE_PASS("metal-device-loads-volatile", MetalDeviceLoadsVolatilePass())
MODULE_PASS("metal-async-event-to-alloca", MetalAsyncEventToAllocaPass())
MODULE_PASS("metal-normalize-allocas", MetalNormalizeAllocasPass())
MODULE_PASS("metal-bfloat16-cast-decompose", MetalBFloat16CastDecomposePass())
MODULE_PASS("metal-scalar-buffer-packing", MetalScalarBufferPackingPass())
MODULE_PASS("metal-air-system-values", MetalAIRSystemValuesPass())
MODULE_PASS("metal-alias-annotate", MetalAliasAnnotatePass())
MODULE_PASS("metal-prepare", MetalPreparePass())
MODULE_PASS("metal-embed", MetalEmbedderPass())
#undef MODULE_PASS

#ifndef FUNCTION_PASS
#define FUNCTION_PASS(NAME, CREATE_PASS)
#endif
#undef FUNCTION_PASS
